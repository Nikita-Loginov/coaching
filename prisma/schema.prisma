generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Program {
  id             String   @id
  name           String
  description    String
  sessions       Int
  months         Int
  price          String
  currency       Currency
  icon           String
  targetAudience String[]
  benefits       String[]
  includes       String[]
  curriculum     Json
  seoTitle       String
  seoDescription String
  seoImage       String
  seoKeywords    String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Review {
  id         String     @id
  authorName String
  authorPost String
  desc       String[]
  targetType TargetType
  createdAt  DateTime   @default(now())
  updatedAt  DateTime
}

model Team {
  id            String   @id
  name          String
  middlename    String
  post          String
  img           String
  city          String?
  info          String[]
  specializing  String[]
  certification String[]
  principle     String
  telegram      String?
  vk            String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime
}

enum Currency {
  rub
  eu
}

enum TargetType {
  program
  course
}
